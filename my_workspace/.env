# ─── Database ─────────────────────────────────────────────
# Dev: SQLite (ไม่ต้องการ Docker)
DATABASE_URL=sqlite+aiosqlite:///./coopform_dev.db
# Production (PostgreSQL via Docker): เปลี่ยนกลับเป็น:
# DATABASE_URL=postgresql+asyncpg://coopuser:coopdev123@db:5432/coopform
POSTGRES_DB=coopform
POSTGRES_USER=coopuser
POSTGRES_PASSWORD=coopdev123

# ─── Security (dev only — เปลี่ยนเมื่อ production) ─────────
SECRET_KEY=dev_secret_key_change_me_in_production_32ch
REFRESH_TOKEN_SECRET=dev_refresh_key_change_me_in_production_32ch

# ─── App ──────────────────────────────────────────────────
ENVIRONMENT=development
