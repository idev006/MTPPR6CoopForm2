# ─────────────────────────────────────────────────────────
#  CoopForm — .env.example  (คัดลอกเป็น .env แล้วแก้ค่า)
#  ห้าม commit ไฟล์ .env จริง!
# ─────────────────────────────────────────────────────────

# ─── Database ─────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://coopuser:change_me_password@db:5432/coopform
POSTGRES_DB=coopform
POSTGRES_USER=coopuser
POSTGRES_PASSWORD=change_me_strong_password

# ─── Security ─────────────────────────────────────────────
SECRET_KEY=change_me_to_random_32_chars_minimum_here_xxxxxxx
REFRESH_TOKEN_SECRET=change_me_another_random_key_yyyyyyyy

# ─── App ──────────────────────────────────────────────────
ENVIRONMENT=development
